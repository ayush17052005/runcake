# Backend environment variables.
# Copy to backend/.env and fill in real values for local development.
# (In Docker these are injected via the root .env / env_file.)

# --- Core ---
# PORT=3001
# NODE_ENV=development
# JWT_SECRET=change-me
# DB_PATH=./data/dev.db

# --- CORS ---
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Google OAuth (optional) ---
# GOOGLE_CLIENT_ID=

# --- Metabase (Business Case Creator: candidate-email fetch, variable lookups) ---
# Base URL of the Metabase instance (no trailing slash).
METABASE_URL=https://metabase.example.com
# API key, sent as the x-api-key header (Metabase 0.49+).
METABASE_API_KEY=
# Saved question (card) id that returns candidate emails for a problem.
# The card must expose a numeric SQL template-tag/parameter for the problem id.
METABASE_CANDIDATE_EMAILS_CARD_ID=
# Slug of that template tag / parameter (defaults to "problem_id" if unset).
METABASE_CANDIDATE_EMAILS_PARAM=problem_id

# --- Update tab cards ---
# Search problems by name/title. Card needs a TEXT template tag (default slug "search").
# Should return an `id` column + a name/title/problem_statement column.
METABASE_PROBLEM_SEARCH_CARD_ID=
METABASE_PROBLEM_SEARCH_PARAM=search
# List a problem's current metric associations. NUMBER template tag (default "problem_id").
# Should return columns: id (metric id), name, description[, min_score, max_score].
METABASE_PROBLEM_METRICS_CARD_ID=
METABASE_PROBLEM_METRICS_PARAM=problem_id
# Search evaluation metrics by name. TEXT template tag (default "search").
# Should return columns: id, name, description.
METABASE_METRIC_SEARCH_CARD_ID=
METABASE_METRIC_SEARCH_PARAM=search
